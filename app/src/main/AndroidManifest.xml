<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 🌐 Network / Backend -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VendorPro"
        tools:targetApi="31">

        <!-- 🚀 SPLASH (LAUNCHER ENTRY POINT) -->
        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 📱 LOGIN – PHONE NUMBER -->
        <activity
            android:name=".ui.LoginActivity"
            android:exported="false" />

        <!-- 🔐 OTP VERIFY -->
        <activity
            android:name=".ui.OtpActivity"
            android:exported="false" />

        <!-- 🏠 DASHBOARD -->
        <activity
            android:name=".ui.DashboardActivity"
            android:exported="false" />

        <!-- 🍽 MENU -->
        <activity
            android:name=".ui.MenuActivity"
            android:exported="false" />

        <!-- 📦 ORDERS -->
        <activity
            android:name=".ui.OrdersActivity"
            android:exported="false" />

        <!-- 📄 ORDER DETAIL -->
        <activity
            android:name=".ui.OrderDetailActivity"
            android:exported="false" />

        <!-- ➕ ADD / ✏️ EDIT MENU ITEM -->
        <activity
            android:name=".ui.AddEditMenuItemActivity"
            android:exported="false" />

        <!-- 🔔 FIREBASE FCM SERVICE -->
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

    </application>

</manifest>