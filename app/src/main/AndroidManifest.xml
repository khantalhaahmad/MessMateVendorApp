<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================
         NETWORK
    ============================================================ -->

    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- ============================================================
         VIBRATION (ORDER ALERT)
    ============================================================ -->

    <uses-permission android:name="android.permission.VIBRATE"/>

    <!-- ============================================================
         NOTIFICATION (Android 13+)
    ============================================================ -->

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <!-- ============================================================
         IMAGE ACCESS
    ============================================================ -->

    <!-- Android 12 and below -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>

    <!-- Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>

    <!-- ============================================================
         APPLICATION
    ============================================================ -->

    <application
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:requestLegacyExternalStorage="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.VendorPro"
        tools:targetApi="33">

        <!-- ============================================================
             SPLASH SCREEN
        ============================================================ -->

        <activity
            android:name=".ui.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AppCompat.NoActionBar">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- ============================================================
             AUTH
        ============================================================ -->

        <activity
            android:name=".ui.AuthLandingActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.LoginActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.OtpActivity"
            android:exported="false"/>

        <!-- ============================================================
             DASHBOARD
        ============================================================ -->

        <activity
            android:name=".ui.DashboardActivity"
            android:exported="false"/>

        <!-- ============================================================
             MENU MANAGEMENT
        ============================================================ -->

        <activity
            android:name=".ui.MenuActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.AddEditMenuItemActivity"
            android:exported="false"/>

        <!-- ============================================================
             ORDERS
        ============================================================ -->

        <activity
            android:name=".ui.OrdersActivity"
            android:exported="false"/>

        <activity
            android:name=".ui.OrderDetailActivity"
            android:exported="false"/>

        <!-- ============================================================
             ANALYTICS
        ============================================================ -->

        <activity
            android:name=".ui.AnalyticsActivity"
            android:exported="false"/>

        <!-- ============================================================
             PAYOUTS
        ============================================================ -->

        <activity
            android:name=".ui.PayoutsActivity"
            android:exported="false"/>

        <!-- ============================================================
             FIREBASE CLOUD MESSAGING
        ============================================================ -->

        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">

            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT"/>
            </intent-filter>

        </service>

    </application>

</manifest>