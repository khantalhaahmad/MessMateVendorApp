<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background Image -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="@android:color/black" />

    <!-- Dark Gradient Overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"/>

    <!-- White Rounded Bottom Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="@drawable/bg_bottom_white"
        android:elevation="10dp">

        <!-- 🔥 Title + Logo Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Title (Left Side) -->
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="VendorPro"
                android:textColor="@android:color/black"
                android:textSize="26sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"/>

            <!-- Logo (Right Side) -->
            <ImageView
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/messmate_logo"
                android:scaleType="fitCenter"/>
        </LinearLayout>


        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage and grow your mess business"
            android:textColor="#555555"
            android:textSize="15sp"
            android:layout_marginBottom="24dp"/>

        <!-- Login Button -->
        <Button
            android:id="@+id/btnLogin"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Login"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.03"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_blue_round"
            android:layout_marginBottom="18dp"/>

        <Button
            android:id="@+id/btnPartner"
            android:layout_width="match_parent"
            android:layout_height="58dp"
            android:text="Partner with VendorPro"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_outline_round"/>

    </LinearLayout>

</FrameLayout>